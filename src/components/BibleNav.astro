---
import bibleStructure from '../data/bible-structure.json';

interface Props {
  currentBook: string;
  currentChapter: number;
}

const { currentBook, currentChapter } = Astro.props;

// Flatten all books into ordered list
const allBooks = [...bibleStructure.testament.OT, ...bibleStructure.testament.NT];
const currentBookIndex = allBooks.findIndex(b => b.slug === currentBook);
const book = allBooks[currentBookIndex];

// Prev / Next logic
let prevHref: string | null = null;
let nextHref: string | null = null;
let prevLabel = '';
let nextLabel = '';

if (currentChapter > 1) {
  prevHref = `/the-upper-room/bible/${currentBook}/${currentChapter - 1}`;
  prevLabel = `${book.name} ${currentChapter - 1}`;
} else if (currentBookIndex > 0) {
  const prevBook = allBooks[currentBookIndex - 1];
  prevHref = `/the-upper-room/bible/${prevBook.slug}/${prevBook.chapters}`;
  prevLabel = `${prevBook.name} ${prevBook.chapters}`;
}

if (currentChapter < book.chapters) {
  nextHref = `/the-upper-room/bible/${currentBook}/${currentChapter + 1}`;
  nextLabel = `${book.name} ${currentChapter + 1}`;
} else if (currentBookIndex < allBooks.length - 1) {
  const nextBook = allBooks[currentBookIndex + 1];
  nextHref = `/the-upper-room/bible/${nextBook.slug}/1`;
  nextLabel = `${nextBook.name} 1`;
}

const chapters = Array.from({ length: book.chapters }, (_, i) => i + 1);
---

<nav class="sticky top-16 z-40 bg-parchment-50 border-b border-parchment-200 shadow-sm">
  <div class="container-upper">
    <div class="flex items-center gap-2 py-2.5">

      <!-- Prev -->
      {prevHref ? (
        <a href={prevHref} id="prev-chapter"
           class="flex-shrink-0 px-3 py-1.5 bg-parchment-200 text-brown-700 hover:bg-parchment-300 hover:text-brown-900 rounded-sm text-sm font-display transition-colors"
           title={prevLabel}>
          ← <span class="hidden sm:inline">{prevLabel}</span>
        </a>
      ) : (
        <span class="flex-shrink-0 px-3 py-1.5 bg-parchment-100 text-parchment-400 rounded-sm text-sm opacity-50 cursor-not-allowed">←</span>
      )}

      <!-- Book dropdown -->
      <select id="book-select"
              class="flex-1 min-w-0 py-1.5 px-2 border border-parchment-300 rounded-sm bg-white text-brown-800 font-serif text-sm cursor-pointer focus:outline-none focus:border-gold-400">
        <optgroup label="Old Testament">
          {bibleStructure.testament.OT.map(b => (
            <option value={b.slug} selected={b.slug === currentBook}>{b.name}</option>
          ))}
        </optgroup>
        <optgroup label="New Testament">
          {bibleStructure.testament.NT.map(b => (
            <option value={b.slug} selected={b.slug === currentBook}>{b.name}</option>
          ))}
        </optgroup>
      </select>

      <!-- Chapter dropdown -->
      <select id="chapter-select"
              class="w-20 py-1.5 px-2 border border-parchment-300 rounded-sm bg-white text-brown-800 font-serif text-sm cursor-pointer focus:outline-none focus:border-gold-400">
        {chapters.map(ch => (
          <option value={ch} selected={ch === currentChapter}>{ch}</option>
        ))}
      </select>

      <!-- Next -->
      {nextHref ? (
        <a href={nextHref} id="next-chapter"
           class="flex-shrink-0 px-3 py-1.5 bg-parchment-200 text-brown-700 hover:bg-parchment-300 hover:text-brown-900 rounded-sm text-sm font-display transition-colors"
           title={nextLabel}>
          <span class="hidden sm:inline">{nextLabel}</span> →
        </a>
      ) : (
        <span class="flex-shrink-0 px-3 py-1.5 bg-parchment-100 text-parchment-400 rounded-sm text-sm opacity-50 cursor-not-allowed">→</span>
      )}

    </div>
  </div>
</nav>

<script define:vars={{ currentBook, currentChapter }}>
  const bookSelect = document.getElementById('book-select');
  const chapterSelect = document.getElementById('chapter-select');

  bookSelect?.addEventListener('change', () => {
    window.location.href = `/the-upper-room/bible/${bookSelect.value}/1`;
  });

  chapterSelect?.addEventListener('change', () => {
    window.location.href = `/the-upper-room/bible/${currentBook}/${chapterSelect.value}`;
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLSelectElement || e.target instanceof HTMLTextAreaElement) return;
    const prev = document.getElementById('prev-chapter');
    const next = document.getElementById('next-chapter');
    if (e.key === 'ArrowLeft' && prev?.href) window.location.href = prev.href;
    if (e.key === 'ArrowRight' && next?.href) window.location.href = next.href;
  });
</script>
