---
import bibleStructure from '../data/bible-structure.json';

interface Props {
  currentBook: string;
  currentChapter: number;
}

const { currentBook, currentChapter } = Astro.props;
const base = import.meta.env.BASE_URL;

// Flatten all books into a single ordered list
const allBooks = [...bibleStructure.testament.OT, ...bibleStructure.testament.NT];

// Find current book index
const currentBookIndex = allBooks.findIndex(b => b.slug === currentBook);
const book = allBooks[currentBookIndex];

// Build prev/next navigation
let prevHref: string | null = null;
let nextHref: string | null = null;
let prevLabel = '';
let nextLabel = '';

if (currentChapter > 1) {
  prevHref = `${base}bible/${currentBook}/${currentChapter - 1}`;
  prevLabel = `${book.name} ${currentChapter - 1}`;
} else if (currentBookIndex > 0) {
  const prevBook = allBooks[currentBookIndex - 1];
  prevHref = `${base}bible/${prevBook.slug}/${prevBook.chapters}`;
  prevLabel = `${prevBook.name} ${prevBook.chapters}`;
}

if (currentChapter < book.chapters) {
  nextHref = `${base}bible/${currentBook}/${currentChapter + 1}`;
  nextLabel = `${book.name} ${currentChapter + 1}`;
} else if (currentBookIndex < allBooks.length - 1) {
  const nextBook = allBooks[currentBookIndex + 1];
  nextHref = `${base}bible/${nextBook.slug}/1`;
  nextLabel = `${nextBook.name} 1`;
}

// Chapter array for dropdown
const chapters = Array.from({ length: book.chapters }, (_, i) => i + 1);
---

<nav class="bible-nav" style="background: #faf7f2; border-bottom: 1px solid #ede5d5; padding: 0.75rem 1rem; position: sticky; top: 0; z-index: 100;">
  <div style="max-width: 70ch; margin: 0 auto; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">

    <!-- Prev button -->
    {prevHref ? (
      <a href={prevHref} id="prev-chapter" style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.4rem 0.75rem; background: #ede5d5; color: #5c3d2e; text-decoration: none; border-radius: 4px; font-size: 0.875rem; font-family: 'EB Garamond', serif; transition: background 0.15s;" aria-label={`Previous: ${prevLabel}`}>
        ← <span class="nav-label" style="display: none;">{prevLabel}</span>
      </a>
    ) : (
      <span style="display: inline-flex; align-items: center; padding: 0.4rem 0.75rem; background: #f5f0e8; color: #c0a87a; border-radius: 4px; font-size: 0.875rem; opacity: 0.5;">←</span>
    )}

    <!-- Book dropdown -->
    <select id="book-select" style="padding: 0.4rem 0.5rem; border: 1px solid #ede5d5; border-radius: 4px; background: white; color: #2c1810; font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; cursor: pointer; flex: 1; min-width: 120px;">
      <optgroup label="Old Testament">
        {bibleStructure.testament.OT.map(b => (
          <option value={b.slug} selected={b.slug === currentBook}>{b.name}</option>
        ))}
      </optgroup>
      <optgroup label="New Testament">
        {bibleStructure.testament.NT.map(b => (
          <option value={b.slug} selected={b.slug === currentBook}>{b.name}</option>
        ))}
      </optgroup>
    </select>

    <!-- Chapter dropdown -->
    <select id="chapter-select" style="padding: 0.4rem 0.5rem; border: 1px solid #ede5d5; border-radius: 4px; background: white; color: #2c1810; font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; cursor: pointer; width: 80px;">
      {chapters.map(ch => (
        <option value={ch} selected={ch === currentChapter}>{ch}</option>
      ))}
    </select>

    <!-- Next button -->
    {nextHref ? (
      <a href={nextHref} id="next-chapter" style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.4rem 0.75rem; background: #ede5d5; color: #5c3d2e; text-decoration: none; border-radius: 4px; font-size: 0.875rem; font-family: 'EB Garamond', serif; transition: background 0.15s;" aria-label={`Next: ${nextLabel}`}>
        <span class="nav-label" style="display: none;">{nextLabel}</span> →
      </a>
    ) : (
      <span style="display: inline-flex; align-items: center; padding: 0.4rem 0.75rem; background: #f5f0e8; color: #c0a87a; border-radius: 4px; font-size: 0.875rem; opacity: 0.5;">→</span>
    )}
  </div>
</nav>

<script define:vars={{ base, allBooks, currentBook, currentChapter }}>
  // Book/chapter dropdown navigation
  const bookSelect = document.getElementById('book-select');
  const chapterSelect = document.getElementById('chapter-select');

  bookSelect?.addEventListener('change', () => {
    const selectedSlug = bookSelect.value;
    window.location.href = `${base}bible/${selectedSlug}/1`;
  });

  chapterSelect?.addEventListener('change', () => {
    const ch = chapterSelect.value;
    window.location.href = `${base}bible/${currentBook}/${ch}`;
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const prevLink = document.getElementById('prev-chapter');
    const nextLink = document.getElementById('next-chapter');

    if (e.key === 'ArrowLeft' && prevLink) {
      window.location.href = prevLink.href;
    } else if (e.key === 'ArrowRight' && nextLink) {
      window.location.href = nextLink.href;
    }
  });
</script>
