---
// Today's reading suggestion based on day of year
const now = new Date();
const start = new Date(now.getFullYear(), 0, 0);
const dayOfYear = Math.floor((now.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));

const readings = [
  { book: 'Psalms', chapter: 23, label: 'Psalm 23', theme: 'The Good Shepherd' },
  { book: 'John', chapter: 1, label: 'John 1', theme: 'The Word made Flesh' },
  { book: 'Romans', chapter: 8, label: 'Romans 8', theme: 'Life in the Spirit' },
  { book: 'Isaiah', chapter: 53, label: 'Isaiah 53', theme: 'The Suffering Servant' },
  { book: 'Hebrews', chapter: 11, label: 'Hebrews 11', theme: 'Faith\'s Hall of Fame' },
  { book: 'Matthew', chapter: 5, label: 'Matthew 5', theme: 'The Sermon on the Mount' },
  { book: 'Philippians', chapter: 4, label: 'Philippians 4', theme: 'The Peace of God' },
];

const todayReading = readings[dayOfYear % readings.length];
---

<div class="bg-brown-900 rounded-sm p-8 text-center relative overflow-hidden">
  <!-- Decorative top line -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-gold-500 to-transparent"></div>

  <span class="text-label text-parchment-500 block mb-2">Today's Reading</span>
  <h3 class="font-display text-2xl font-bold text-parchment-100 mb-2">
    {todayReading.label}
  </h3>
  <p class="text-parchment-400 italic text-sm mb-6">{todayReading.theme}</p>
  <a href={`/the-upper-room/bible/${todayReading.book.toLowerCase().replace(/\s+/g, '-')}/${todayReading.chapter}`} class="btn-gold">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
    </svg>
    Open Bible Reader
  </a>

  <div class="mt-6 pt-6 border-t border-parchment-800/30 text-parchment-600 text-xs">
    ESV® Bible — English Standard Version
  </div>
</div>
