---
interface Props {
  passageHtml: string;
  bookName: string;
  chapter: number;
  wordCount?: number;
}

const { passageHtml, bookName, chapter, wordCount = 0 } = Astro.props;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
---

<article class="container-upper py-10" data-pagefind-body
         data-pagefind-meta={`title:${bookName} ${chapter}`}>

  <header class="max-w-prose-wide mx-auto mb-8 text-center">
    <span class="text-label text-gold-500 block mb-2">ESV® Bible</span>
    <h1 class="font-display text-display-lg font-bold text-brown-900 mb-1">{bookName}</h1>
    <p class="font-display text-xl text-brown-600 italic">Chapter {chapter}</p>
    {wordCount > 0 && (
      <p class="text-xs text-parchment-500 mt-2 font-serif">~{readingMinutes} min read</p>
    )}
    <div class="section-rule mt-6 mb-0"></div>
  </header>

  <div class="prose-scripture max-w-prose-wide mx-auto" set:html={passageHtml} />

  <footer class="max-w-prose-wide mx-auto mt-12 pt-6 border-t border-parchment-200 text-center">
    <p class="text-xs text-parchment-500 font-serif leading-relaxed">
      Scripture quotations are from the ESV® Bible (The Holy Bible, English Standard Version®),
      copyright © 2001 by Crossway, a publishing ministry of Good News Publishers.
      Used by permission. All rights reserved.
    </p>
  </footer>
</article>

<style>
  /* Bible passage typography */
  .prose-scripture {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.2rem;
    line-height: 1.9;
    color: #2a1a10;
  }

  .prose-scripture h2,
  .prose-scripture h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #5a311a;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-style: italic;
    letter-spacing: 0.01em;
  }

  /* Words of Christ — red letters */
  .prose-scripture :global(.woc),
  .prose-scripture :global(span.woc) {
    color: #8b1a1a !important;
  }

  /* Verse numbers — gold superscript */
  .prose-scripture :global(.verse-num),
  .prose-scripture :global(b.verse-num) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.65em;
    font-weight: 600;
    color: #b8860b;
    vertical-align: super;
    line-height: 0;
    margin-right: 0.2em;
    font-style: normal;
  }

  /* Chapter number — large drop cap */
  .prose-scripture :global(.chapter-num) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.5em;
    font-weight: 700;
    color: #b8860b;
    float: left;
    line-height: 0.8;
    margin-right: 0.08em;
    padding-bottom: 0.05em;
  }

  .prose-scripture p {
    margin-bottom: 1.1em;
  }

  /* ESV API adds redundant chapter header — hide it */
  .prose-scripture :global(h2.extra_text) {
    display: none;
  }

  /* Block indent (poetry indentation) */
  .prose-scripture :global(p.block-indent),
  .prose-scripture :global(.block-indent) {
    margin-left: 2em;
  }

  /* Audio link — hide */
  .prose-scripture :global(.audio),
  .prose-scripture :global(.audio.extra_text) {
    display: none;
  }
</style>
