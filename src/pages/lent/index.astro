---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Lent 2026: Ash Wednesday Feb 18, Easter April 5
// Day 1 = Feb 18, Day 21 = March 10 (today), Day 40 = April 4
// Easter (Day 41, not counted in 40) = April 5

const TODAY_DAY = 21; // March 10, 2026

// Easter countdown: April 5 - March 10 = 26 days
const DAYS_TO_EASTER = 26;

interface LentDay {
  day: number;
  date: string;
  passage: string;
  theme: string;
  week: string;
}

const lentDays: LentDay[] = [
  // Week 1: Ash Wednesday – Feb 22
  { day: 1,  date: 'Feb 18', passage: 'Joel 2:12-13',       theme: 'Repentance',                    week: 'Week 1 — Ash Wednesday' },
  { day: 2,  date: 'Feb 19', passage: 'Psalm 51',           theme: 'A Clean Heart',                 week: 'Week 1 — Ash Wednesday' },
  { day: 3,  date: 'Feb 20', passage: 'Isaiah 58:1-9',      theme: 'True Fasting',                  week: 'Week 1 — Ash Wednesday' },
  { day: 4,  date: 'Feb 21', passage: 'Matthew 4:1-11',     theme: 'Temptation of Christ',          week: 'Week 1 — Ash Wednesday' },
  { day: 5,  date: 'Feb 22', passage: 'Mark 1:9-15',        theme: 'The Wilderness',                week: 'Week 1 — Ash Wednesday' },
  // Week 2: Feb 23 – Mar 1
  { day: 6,  date: 'Feb 23', passage: 'Luke 4:1-13',        theme: 'Spirit-Led',                    week: 'Week 2' },
  { day: 7,  date: 'Feb 24', passage: 'John 3:1-21',        theme: 'Born Again',                    week: 'Week 2' },
  { day: 8,  date: 'Feb 25', passage: 'Genesis 3:1-19',     theme: 'The Fall',                      week: 'Week 2' },
  { day: 9,  date: 'Feb 26', passage: 'Romans 5:12-21',     theme: 'Death and Life in Adam/Christ', week: 'Week 2' },
  { day: 10, date: 'Feb 27', passage: 'Psalm 32',           theme: 'Forgiveness',                   week: 'Week 2' },
  { day: 11, date: 'Feb 28', passage: 'Luke 4:1-13',        theme: 'Spirit-Led (revisit)',          week: 'Week 2' },
  { day: 12, date: 'Mar 1',  passage: 'John 3:1-21',        theme: 'Born Again (revisit)',          week: 'Week 2' },
  // Week 3: Mar 2 – Mar 8
  { day: 13, date: 'Mar 2',  passage: 'Hebrews 4:14-16',   theme: 'A Sympathizing High Priest',    week: 'Week 3' },
  { day: 14, date: 'Mar 3',  passage: 'Isaiah 53:1-6',      theme: 'The Suffering Servant',         week: 'Week 3' },
  { day: 15, date: 'Mar 4',  passage: 'Philippians 2:5-11', theme: 'The Kenosis',                   week: 'Week 3' },
  { day: 16, date: 'Mar 5',  passage: 'Matthew 26:36-46',  theme: 'Gethsemane',                    week: 'Week 3' },
  { day: 17, date: 'Mar 6',  passage: 'John 13:1-17',       theme: 'The Washing',                   week: 'Week 3' },
  { day: 18, date: 'Mar 7',  passage: 'Isaiah 53:1-6',      theme: 'The Suffering Servant (revisit)', week: 'Week 3' },
  { day: 19, date: 'Mar 8',  passage: 'Philippians 2:5-11', theme: 'The Kenosis (revisit)',         week: 'Week 3' },
  // Week 4: Mar 9 – Mar 15
  { day: 20, date: 'Mar 9',  passage: 'Psalm 22',           theme: 'My God, Why?',                  week: 'Week 4' },
  { day: 21, date: 'Mar 10', passage: 'Romans 8:1-17',      theme: 'No Condemnation',               week: 'Week 4' },
  { day: 22, date: 'Mar 11', passage: '2 Corinthians 5:14-21', theme: 'Reconciliation',             week: 'Week 4' },
  { day: 23, date: 'Mar 12', passage: 'Isaiah 40:28-31',    theme: 'Strength Renewed',              week: 'Week 4' },
  { day: 24, date: 'Mar 13', passage: 'Lamentations 3:19-33', theme: 'Great Is Thy Faithfulness',  week: 'Week 4' },
  { day: 25, date: 'Mar 14', passage: 'Romans 8:1-17',      theme: 'No Condemnation (revisit)',     week: 'Week 4' },
  { day: 26, date: 'Mar 15', passage: '2 Corinthians 5:14-21', theme: 'Reconciliation (revisit)',  week: 'Week 4' },
  // Week 5: Mar 16 – Mar 22
  { day: 27, date: 'Mar 16', passage: 'John 11:1-44',       theme: 'Lazarus',                       week: 'Week 5' },
  { day: 28, date: 'Mar 17', passage: 'Romans 3:21-26',     theme: 'Justification',                 week: 'Week 5' },
  { day: 29, date: 'Mar 18', passage: 'Hebrews 9:11-14',    theme: 'The Better Sacrifice',          week: 'Week 5' },
  { day: 30, date: 'Mar 19', passage: 'Exodus 12:1-14',     theme: 'The Passover',                  week: 'Week 5' },
  { day: 31, date: 'Mar 20', passage: '1 Peter 1:17-21',    theme: 'Redeemed',                      week: 'Week 5' },
  { day: 32, date: 'Mar 21', passage: 'John 11:1-44',       theme: 'Lazarus (revisit)',             week: 'Week 5' },
  { day: 33, date: 'Mar 22', passage: 'Romans 3:21-26',     theme: 'Justification (revisit)',       week: 'Week 5' },
  // Week 6: Mar 23 – Mar 29
  { day: 34, date: 'Mar 23', passage: 'Zechariah 9:9',      theme: 'The Coming King',               week: 'Week 6 — Palm Sunday Week' },
  { day: 35, date: 'Mar 24', passage: 'Matthew 21:1-11',    theme: 'Triumphal Entry',               week: 'Week 6 — Palm Sunday Week' },
  { day: 36, date: 'Mar 25', passage: 'John 12:20-36',      theme: 'Unless a Grain of Wheat',       week: 'Week 6 — Palm Sunday Week' },
  { day: 37, date: 'Mar 26', passage: 'Isaiah 50:4-9',      theme: 'The Servant Obedient',          week: 'Week 6 — Palm Sunday Week' },
  { day: 38, date: 'Mar 27', passage: 'Mark 14:1-11',       theme: 'The Anointing',                 week: 'Week 6 — Palm Sunday Week' },
  { day: 39, date: 'Mar 28', passage: 'Matthew 21:1-11',    theme: 'Triumphal Entry (revisit)',     week: 'Week 6 — Palm Sunday Week' },
  { day: 40, date: 'Mar 29', passage: 'John 12:20-36',      theme: 'Unless a Grain of Wheat (revisit)', week: 'Week 6 — Palm Sunday Week' },
];

// Holy Week: Mar 30 – Apr 4 (these are additional, post-40-day)
const holyWeekDays = [
  { day: 'HW1', date: 'Mar 30', passage: 'Matthew 26:1-29',  theme: 'Last Supper',            label: 'Monday of Holy Week' },
  { day: 'HW2', date: 'Mar 31', passage: 'John 18:1-27',     theme: 'Betrayal',               label: 'Tuesday of Holy Week' },
  { day: 'HW3', date: 'Apr 1',  passage: 'John 18:28–19:16', theme: 'The Trial',              label: 'Wednesday of Holy Week' },
  { day: 'HW4', date: 'Apr 2',  passage: 'John 19:17-42',    theme: 'The Crucifixion',        label: 'Maundy Thursday' },
  { day: 'HW5', date: 'Apr 3',  passage: 'Luke 23:50-56',    theme: 'The Tomb',               label: 'Good Friday' },
  { day: 'HW6', date: 'Apr 4',  passage: 'Isaiah 25:6-9',    theme: 'He Will Swallow Up Death', label: 'Holy Saturday' },
];

// Group lentDays by week label
const weeks: Record<string, LentDay[]> = {};
for (const day of lentDays) {
  if (!weeks[day.week]) weeks[day.week] = [];
  weeks[day.week].push(day);
}
---

<BaseLayout
  title="Lent 2026 — 40-Day Reading Plan"
  description="A 40-day reading plan for Lent 2026, from Ash Wednesday (February 18) to Holy Saturday (April 4), preparing the soul for Easter."
  path="/lent/"
>

  <!-- LENT HEADER -->
  <div class="lent-header border-b" style="background: #3d1a24; border-color: rgba(107,45,62,0.4);">
    <div class="container-upper py-14 md:py-18">

      <!-- Cross icon + label -->
      <div class="flex items-center gap-3 mb-5">
        <svg class="w-8 h-8 flex-shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="14" y="2" width="4" height="28" rx="1.5" fill="#9b5a6a"/>
          <rect x="4" y="10" width="24" height="4" rx="1.5" fill="#9b5a6a"/>
        </svg>
        <span class="text-label tracking-widest" style="color: #c98a9a; font-size: 0.65rem;">Lent 2026</span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-display-md md:text-display-lg font-bold leading-tight mb-4 max-w-2xl" style="color: #f5e6ea;">
        40-Day Lenten Reading Plan
      </h1>

      <!-- Dates + description -->
      <p class="font-serif text-lg leading-relaxed max-w-2xl mb-8" style="color: #d4a8b5;">
        Ash Wednesday, February 18 &mdash; Holy Saturday, April 4, 2026.
        Forty days of Scripture and prayer, preparing the heart to receive Easter.
      </p>

      <!-- Easter countdown -->
      <div class="inline-flex items-center gap-3 rounded-sm px-5 py-3" style="background: rgba(107,45,62,0.5); border: 1px solid rgba(155,90,106,0.4);">
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="10" cy="10" r="8" stroke="#c98a9a" stroke-width="1.5"/>
          <path d="M10 6v4l3 2" stroke="#c98a9a" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="font-display text-sm font-semibold" style="color: #f5e6ea;">
          {DAYS_TO_EASTER} days until Easter &mdash; April 5, 2026
        </span>
      </div>

    </div>
  </div>

  <!-- INTRO -->
  <div style="background: #f9f0f3; border-bottom: 1px solid #e8d0d8;">
    <div class="container-upper py-10">
      <div class="max-w-prose mx-auto">
        <p class="font-serif text-brown-800 text-base md:text-lg leading-relaxed mb-4">
          Lent is the ancient Christian season of forty days (not counting Sundays) preceding Easter. It
          takes its shape from Christ's forty days of fasting in the wilderness, and from Israel's forty years
          of desert wandering. It is a season for self-examination, repentance, prayer, fasting, and renewed
          attention to the Scriptures — not as punishment, but as preparation.
        </p>
        <p class="font-serif text-brown-700 text-base md:text-lg leading-relaxed mb-4">
          The readings below move through themes of repentance, the suffering servant, the cost of
          discipleship, and finally the events of Holy Week. Each day offers a passage and a brief theme.
          Read slowly. Pray the text. Let Lent do its work.
        </p>
        <div class="flex flex-wrap items-center gap-6 mt-6 pt-6 border-t border-parchment-200">
          <div class="flex items-center gap-2 text-sm font-serif">
            <span class="w-4 h-4 rounded-sm flex-shrink-0" style="background: #d4edda; border: 1px solid #a8d5b0;"></span>
            <span class="text-brown-600">Completed (Days 1–{TODAY_DAY - 1})</span>
          </div>
          <div class="flex items-center gap-2 text-sm font-serif">
            <span class="w-4 h-4 rounded-sm flex-shrink-0" style="background: #fff3cd; border: 2px solid #b8860b;"></span>
            <span class="text-brown-600">Today (Day {TODAY_DAY})</span>
          </div>
          <div class="flex items-center gap-2 text-sm font-serif">
            <span class="w-4 h-4 rounded-sm flex-shrink-0" style="background: #f8eddb; border: 1px solid #f0d9b0;"></span>
            <span class="text-brown-600">Upcoming</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- READING PLAN -->
  <div class="container-upper py-12" data-pagefind-body>

    {Object.entries(weeks).map(([weekLabel, days]) => (
      <section class="mb-12">
        <!-- Week header -->
        <div class="flex items-center gap-4 mb-5">
          <h2 class="font-display text-base font-bold tracking-wide flex-shrink-0" style="color: #6b2d3e;">
            {weekLabel}
          </h2>
          <div class="flex-1 border-t" style="border-color: #e8d0d8;"></div>
          <span class="text-xs font-serif flex-shrink-0" style="color: #9b5a6a;">
            {days[0].date} &ndash; {days[days.length - 1].date}
          </span>
        </div>

        <!-- Days grid -->
        <div class="space-y-2 md:space-y-0 md:grid md:grid-cols-1 lg:grid-cols-1">
          {days.map((day) => {
            const isToday = day.day === TODAY_DAY;
            const isDone = day.day < TODAY_DAY;
            return (
              <div
                class={`lent-day-row flex items-center gap-4 rounded-sm px-4 py-3 transition-colors ${
                  isToday
                    ? 'lent-today'
                    : isDone
                    ? 'lent-done'
                    : 'lent-upcoming'
                }`}
              >
                <!-- Day number -->
                <div class="flex-shrink-0 w-10 text-center">
                  {isToday ? (
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-full font-display font-bold text-sm" style="background: #b8860b; color: #fff;">
                      {day.day}
                    </span>
                  ) : isDone ? (
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-full font-display text-sm" style="background: rgba(107,45,62,0.12); color: #6b2d3e;">
                      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Completed">
                        <path d="M3 8l3.5 3.5L13 5" stroke="#6b2d3e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  ) : (
                    <span class="inline-flex items-center justify-center w-9 h-9 rounded-full font-display text-sm font-semibold" style="background: rgba(184,134,11,0.1); color: #9a7209;">
                      {day.day}
                    </span>
                  )}
                </div>

                <!-- Date -->
                <div class="flex-shrink-0 w-14 text-xs font-display tracking-wide" style={isToday ? 'color: #b8860b; font-weight: 700;' : isDone ? 'color: #6b2d3e; opacity: 0.7;' : 'color: #8a5225;'}>
                  {day.date}
                </div>

                <!-- Passage + theme -->
                <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-center sm:gap-4">
                  <span class={`font-serif text-sm font-semibold flex-shrink-0 ${isToday ? '' : isDone ? 'opacity-75' : ''}`} style={isToday ? 'color: #3d2b1f;' : isDone ? 'color: #3d2b1f;' : 'color: #3d2b1f;'}>
                    {day.passage}
                  </span>
                  <span class="font-serif text-xs truncate" style={isToday ? 'color: #6b2d3e; font-style: italic;' : isDone ? 'color: #8a5225; font-style: italic; opacity: 0.8;' : 'color: #8a5225; font-style: italic;'}>
                    {day.theme}
                  </span>
                </div>

                <!-- Today badge -->
                {isToday && (
                  <div class="flex-shrink-0 ml-auto">
                    <span class="inline-block font-display font-bold text-xs tracking-wider uppercase px-2 py-0.5 rounded-sm" style="background: #b8860b; color: #fff;">
                      Today
                    </span>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    ))}

    <!-- Holy Week -->
    <section class="mb-12">
      <div class="flex items-center gap-4 mb-5">
        <h2 class="font-display text-base font-bold tracking-wide flex-shrink-0" style="color: #6b2d3e;">
          Holy Week
        </h2>
        <div class="flex-1 border-t" style="border-color: #e8d0d8;"></div>
        <span class="text-xs font-serif flex-shrink-0" style="color: #9b5a6a;">Mar 30 &ndash; Apr 4</span>
      </div>

      <div class="space-y-2">
        {holyWeekDays.map((day) => (
          <div class="lent-day-row lent-upcoming flex items-center gap-4 rounded-sm px-4 py-3">
            <div class="flex-shrink-0 w-10 text-center">
              <span class="inline-flex items-center justify-center w-9 h-9 rounded-full font-display text-sm font-semibold" style="background: rgba(107,45,62,0.15); color: #6b2d3e;">
                ✝
              </span>
            </div>
            <div class="flex-shrink-0 w-14 text-xs font-display tracking-wide" style="color: #6b2d3e; font-weight: 600;">
              {day.date}
            </div>
            <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-center sm:gap-4">
              <span class="font-serif text-sm font-semibold flex-shrink-0" style="color: #3d2b1f;">{day.passage}</span>
              <span class="font-serif text-xs italic truncate" style="color: #6b2d3e;">{day.theme}</span>
            </div>
            <div class="flex-shrink-0 hidden sm:block">
              <span class="text-xs font-display tracking-wide" style="color: #9b5a6a;">{day.label}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Easter -->
    <section class="mb-16">
      <div class="rounded-sm px-6 py-8 text-center" style="background: linear-gradient(135deg, #3d1a24 0%, #5a2535 100%); border: 1px solid rgba(155,90,106,0.3);">
        <div class="flex items-center justify-center gap-3 mb-3">
          <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="16" cy="16" r="12" stroke="#d4a017" stroke-width="1.5" stroke-dasharray="3 2"/>
            <path d="M16 8v8l5 3" stroke="#d4a017" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="text-label tracking-widest" style="color: #d4a017; font-size: 0.65rem;">Easter Sunday</span>
        </div>
        <p class="font-display text-xl md:text-2xl font-bold mb-2" style="color: #f5e6ea;">April 5, 2026</p>
        <p class="font-serif text-sm mb-5" style="color: #d4a8b5;">1 Corinthians 15:1-20 — The Resurrection Gospel</p>
        <p class="font-serif italic text-base md:text-lg max-w-sm mx-auto" style="color: #f5e6ea; opacity: 0.9;">
          "But now Christ has been raised from the dead, the first fruits of those who are asleep."
        </p>
        <p class="text-xs font-display tracking-wide mt-2" style="color: #9b5a6a;">1 Corinthians 15:20, WEB</p>
      </div>
    </section>

    <!-- Links -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pb-4">
      <a href="/the-upper-room/studies/lenten-repentance/" class="btn-gold text-sm">
        Study: Lenten Repentance
      </a>
      <a href="/the-upper-room/bible/" class="btn-outline text-sm">
        Open Bible Reader
      </a>
      <a href="/the-upper-room/studies/" class="font-display text-sm text-brown-600 hover:text-brown-900 transition-colors">
        All Studies &rarr;
      </a>
    </div>

  </div>

</BaseLayout>

<style>
  .lent-done {
    background: #f0faf2;
    border: 1px solid #c8e6cc;
  }
  .lent-today {
    background: #fffbeb;
    border: 2px solid #b8860b;
    box-shadow: 0 1px 6px rgba(184,134,11,0.15);
  }
  .lent-upcoming {
    background: #fdf8f0;
    border: 1px solid #f0d9b0;
  }
  .lent-day-row {
    transition: all 0.15s ease;
  }
  .lent-upcoming:hover {
    background: #f8eddb;
  }
</style>
