---
import bibleStructure from '../../../data/bible-structure.json';

// Lightweight redirect pages — send users to the SPA reader at /bible/#book/chapter
export function getStaticPaths() {
  const paths = [];
  const allBooks = [...bibleStructure.testament.OT, ...bibleStructure.testament.NT];
  for (const book of allBooks) {
    for (let ch = 1; ch <= book.chapters; ch++) {
      paths.push({ params: { book: book.slug, chapter: String(ch) } });
    }
  }
  return paths;
}

const { book, chapter } = Astro.params;
const target = `/the-upper-room/bible/#${book}/${chapter}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <title>Bible Reader — The Upper Room</title>
  <link rel="manifest" href="/the-upper-room/manifest.json" />
  <meta name="theme-color" content="#3d2b1f" />
</head>
<body style="background:#faf4e8; font-family:'EB Garamond',Georgia,serif; text-align:center; padding:3rem;">
  <p style="color:#8a5225; font-style:italic;">Loading Bible reader…</p>
  <script define:vars={{ target }}>window.location.replace(target);</script>
</body>
</html>
