---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BibleNav from '../../../components/BibleNav.astro';
import BibleReader from '../../../components/BibleReader.astro';
import bibleStructure from '../../../data/bible-structure.json';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const paths = [];
  const allBooks = [...bibleStructure.testament.OT, ...bibleStructure.testament.NT];
  for (const book of allBooks) {
    for (let ch = 1; ch <= book.chapters; ch++) {
      paths.push({
        params: { book: book.slug, chapter: String(ch) },
        props: { bookData: book },
      });
    }
  }
  return paths;
}

const { book: bookSlug, chapter: chapterStr } = Astro.params;
const { bookData } = Astro.props;
const chapter = parseInt(chapterStr, 10);

const cacheFile = join(process.cwd(), 'src', 'data', 'esv-cache', `${bookSlug}-${chapter}.json`);

let passageHtml = '';
let wordCount = 0;

if (existsSync(cacheFile)) {
  try {
    const cached = JSON.parse(readFileSync(cacheFile, 'utf8'));
    passageHtml = cached.html ?? '';
    if (passageHtml) {
      const textContent = passageHtml.replace(/<[^>]+>/g, ' ');
      wordCount = textContent.trim().split(/\s+/).filter(Boolean).length;
    }
  } catch {
    passageHtml = '';
  }
}

const hasCachedContent = !!passageHtml;
const spaFallback = `/the-upper-room/bible/#${bookSlug}/${chapter}`;
---

<BaseLayout
  title={`${bookData.name} ${chapter}`}
  description={`Read ${bookData.name} chapter ${chapter} in the English Standard Version (ESV) Bible.`}
  path={`/bible/${bookSlug}/${chapter}/`}
>
  {hasCachedContent ? (
    <>
      <BibleNav currentBook={bookSlug} currentChapter={chapter} />
      <BibleReader
        passageHtml={passageHtml}
        bookName={bookData.name}
        chapter={chapter}
        wordCount={wordCount}
      />
    </>
  ) : (
    <div style="text-align:center; padding:3rem; font-family:'EB Garamond',Georgia,serif;">
      <p style="color:#8a5225; font-style:italic;">Loading {bookData.name} {chapter}…</p>
      <script define:vars={{ spaFallback }}>
        window.location.replace(spaFallback);
      </script>
    </div>
  )}
</BaseLayout>
