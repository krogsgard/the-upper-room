---
import BaseLayout from '../../layouts/BaseLayout.astro';
import bibleStructure from '../../data/bible-structure.json';

const featured = [
  { book: 'psalms', chapter: 23, label: 'Psalm 23', desc: 'The LORD is my shepherd; I shall not want.' },
  { book: 'john', chapter: 3, label: 'John 3', desc: 'For God so loved the world…' },
  { book: 'romans', chapter: 8, label: 'Romans 8', desc: 'More than conquerors through him who loved us.' },
  { book: 'isaiah', chapter: 53, label: 'Isaiah 53', desc: 'He was pierced for our transgressions.' },
];
---

<BaseLayout title="Bible Reader" description="Read all 66 books of the Holy Bible (ESV) with The Upper Room's clean, focused devotional reader." path="/bible/">
  <div class="container-upper py-12">

    <!-- Header -->
    <div class="mb-10 text-center">
      <span class="text-label text-gold-500 block mb-3">English Standard Version</span>
      <h1 class="font-display text-display-md font-bold text-brown-900 mb-3">Holy Bible</h1>
      <p class="text-brown-700 font-serif text-lg max-w-xl mx-auto leading-relaxed">
        All 66 books — beautifully typeset for devotional reading, with red letters and careful typography.
      </p>
    </div>

    <!-- Featured Passages -->
    <section class="mb-12">
      <h2 class="text-label text-parchment-600 text-center mb-5">Beloved Passages</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {featured.map(f => (
          <a href={`/the-upper-room/bible/${f.book}/${f.chapter}`}
             class="card-parchment hover:border-gold-400 transition-colors block no-underline group">
            <div class="font-display font-semibold text-brown-900 mb-1 group-hover:text-gold-600 transition-colors">{f.label}</div>
            <div class="font-serif text-sm text-brown-600 italic leading-snug">{f.desc}</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Two-column book grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

      <!-- Old Testament -->
      <section>
        <div class="flex items-center gap-3 mb-5">
          <h2 class="font-display font-bold text-brown-900 text-xl">Old Testament</h2>
          <span class="text-label text-parchment-500">39 Books</span>
        </div>
        <ul class="space-y-0.5" role="list">
          {bibleStructure.testament.OT.map(book => (
            <li>
              <a href={`/the-upper-room/bible/${book.slug}/1`}
                 class="flex justify-between items-center py-1.5 px-2 rounded-sm text-brown-800 hover:bg-parchment-200 hover:text-brown-900 transition-colors font-serif text-base group">
                <span>{book.name}</span>
                <span class="text-xs text-parchment-500 group-hover:text-gold-500 transition-colors">{book.chapters} ch</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- New Testament -->
      <section>
        <div class="flex items-center gap-3 mb-5">
          <h2 class="font-display font-bold text-brown-900 text-xl">New Testament</h2>
          <span class="text-label text-parchment-500">27 Books</span>
        </div>
        <ul class="space-y-0.5" role="list">
          {bibleStructure.testament.NT.map(book => (
            <li>
              <a href={`/the-upper-room/bible/${book.slug}/1`}
                 class="flex justify-between items-center py-1.5 px-2 rounded-sm text-brown-800 hover:bg-parchment-200 hover:text-brown-900 transition-colors font-serif text-base group">
                <span>{book.name}</span>
                <span class="text-xs text-parchment-500 group-hover:text-gold-500 transition-colors">{book.chapters} ch</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

    </div>

  </div>
</BaseLayout>
