---
import BaseLayout from '../../layouts/BaseLayout.astro';
import bibleStructure from '../../data/bible-structure.json';

// Psalm 23 static ESV text — rendered server-side as the default/fallback
const psalm23Html = `<p><b class="verse-num">1</b> The <span class="small-caps">Lord</span> is my shepherd; I shall not want.</p>
<p><b class="verse-num">2</b> He makes me lie down in green pastures. He leads me beside still waters.</p>
<p><b class="verse-num">3</b> He restores my soul. He leads me in paths of righteousness for his name&#x2019;s sake.</p>
<p><b class="verse-num">4</b> Even though I walk through the valley of the shadow of death, I will fear no evil, for you are with me; your rod and your staff, they comfort me.</p>
<p><b class="verse-num">5</b> You prepare a table before me in the presence of my enemies; you anoint my head with oil; my cup overflows.</p>
<p><b class="verse-num">6</b> Surely goodness and mercy shall follow me all the days of my life, and I shall dwell in the house of the <span class="small-caps">Lord</span> forever.</p>`;

const booksFlat = [
  ...bibleStructure.testament.OT.map(b => ({ ...b, testament: 'OT' as const })),
  ...bibleStructure.testament.NT.map(b => ({ ...b, testament: 'NT' as const })),
];
---

<BaseLayout
  title="Bible Reader"
  description="Read all 66 books of the Holy Bible (ESV) with The Upper Room's clean, focused devotional reader."
  path="/bible/"
>

  <!-- Full-height reader layout -->
  <div style="display:flex; height:calc(100vh - 4rem); overflow:hidden;">

    <!-- Sidebar -->
    <aside id="bible-sidebar"
      style="width:240px; flex-shrink:0; overflow-y:auto; background:#fdf8f0; border-right:1px solid #e5c07e; display:none;"
      class="lg-show"
    >
      <div style="padding:1rem 0.75rem;">
        <div style="font-family:'Playfair Display',Georgia,serif; font-size:0.65rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#c4873a; margin-bottom:0.5rem; padding:0 0.5rem;">
          Old Testament
        </div>
        {bibleStructure.testament.OT.map(book => (
          <button
            data-book={book.slug}
            data-chapters={book.chapters}
            data-name={book.name}
            class="book-btn"
            style="display:flex; justify-content:space-between; width:100%; background:none; border:none; cursor:pointer; padding:0.25rem 0.5rem; border-radius:3px; font-family:'EB Garamond',Georgia,serif; font-size:0.95rem; color:#3d2b1f; text-align:left; transition:background 0.15s;"
          >
            <span>{book.name}</span>
            <span style="font-size:0.7rem; color:#c4873a;">{book.chapters}</span>
          </button>
        ))}
        <div style="font-family:'Playfair Display',Georgia,serif; font-size:0.65rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#c4873a; margin:1rem 0 0.5rem; padding:0 0.5rem;">
          New Testament
        </div>
        {bibleStructure.testament.NT.map(book => (
          <button
            data-book={book.slug}
            data-chapters={book.chapters}
            data-name={book.name}
            class="book-btn"
            style="display:flex; justify-content:space-between; width:100%; background:none; border:none; cursor:pointer; padding:0.25rem 0.5rem; border-radius:3px; font-family:'EB Garamond',Georgia,serif; font-size:0.95rem; color:#3d2b1f; text-align:left; transition:background 0.15s;"
          >
            <span>{book.name}</span>
            <span style="font-size:0.7rem; color:#c4873a;">{book.chapters}</span>
          </button>
        ))}
      </div>
    </aside>

    <!-- Reader main area -->
    <div style="flex:1; display:flex; flex-direction:column; overflow:hidden; background:#faf7f2;">

      <!-- Top bar -->
      <div style="background:#fdf8f0; border-bottom:1px solid #ede5d5; padding:0.5rem 1rem; display:flex; align-items:center; gap:0.5rem; flex-shrink:0; flex-wrap:wrap;">
        <button id="sidebar-toggle"
          style="background:none; border:none; cursor:pointer; padding:0.3rem; color:#8a5225; display:flex; align-items:center; flex-shrink:0;"
          aria-label="Toggle book list"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
        <select id="book-select"
          style="font-family:'EB Garamond',Georgia,serif; font-size:0.9rem; border:1px solid #ede5d5; border-radius:3px; padding:0.2rem 0.4rem; background:white; color:#3d2b1f; cursor:pointer; flex:1; min-width:120px; max-width:220px;">
          <optgroup label="Old Testament">
            {bibleStructure.testament.OT.map(b => (
              <option value={b.slug} selected={b.slug === 'psalms'}>{b.name}</option>
            ))}
          </optgroup>
          <optgroup label="New Testament">
            {bibleStructure.testament.NT.map(b => (
              <option value={b.slug}>{b.name}</option>
            ))}
          </optgroup>
        </select>
        <select id="chapter-select"
          style="font-family:'EB Garamond',Georgia,serif; font-size:0.9rem; border:1px solid #ede5d5; border-radius:3px; padding:0.2rem 0.4rem; background:white; color:#3d2b1f; cursor:pointer; width:64px;">
          {Array.from({ length: 150 }, (_, i) => (
            <option value={i + 1} selected={i === 22}>{i + 1}</option>
          ))}
        </select>
        <div style="margin-left:auto; display:flex; gap:0.5rem; flex-shrink:0;">
          <button id="prev-btn"
            style="font-family:'Playfair Display',Georgia,serif; font-size:0.8rem; padding:0.25rem 0.75rem; border:1px solid #b8860b; color:#9a7209; background:none; cursor:pointer; border-radius:2px; transition:all 0.15s;">
            ← Prev
          </button>
          <button id="next-btn"
            style="font-family:'Playfair Display',Georgia,serif; font-size:0.8rem; padding:0.25rem 0.75rem; border:1px solid #b8860b; color:#9a7209; background:none; cursor:pointer; border-radius:2px; transition:all 0.15s;">
            Next →
          </button>
        </div>
      </div>

      <!-- Scrollable scripture area -->
      <div id="scroll-area" style="flex:1; overflow-y:auto;">
        <div style="max-width:68ch; margin:0 auto; padding:2.5rem 1.5rem 5rem;">

          <!-- Loading -->
          <div id="loading" style="display:none; text-align:center; padding:4rem 0;">
            <div style="display:inline-block; width:2rem; height:2rem; border:2px solid #b8860b; border-top-color:transparent; border-radius:50%; animation:spin 0.8s linear infinite;"></div>
            <p style="font-family:'EB Garamond',Georgia,serif; color:#c4873a; font-style:italic; margin-top:1rem;">Loading Scripture…</p>
          </div>

          <!-- Error -->
          <div id="error-state" style="display:none; text-align:center; padding:4rem 0;">
            <p style="font-family:'EB Garamond',Georgia,serif; color:#8a5225; font-style:italic; font-size:1.1rem; margin-bottom:0.75rem;">
              This chapter could not be loaded.
            </p>
            <p style="font-family:'EB Garamond',Georgia,serif; color:#c4873a; font-size:0.9rem;">
              ESV API access required. <a href="https://api.esv.org" target="_blank" rel="noopener" style="color:#9a7209;">Get a key →</a>
            </p>
          </div>

          <!-- Scripture article -->
          <article id="scripture-article" data-pagefind-body>
            <header style="text-align:center; margin-bottom:2rem; padding-bottom:1.5rem; border-bottom:1px solid #ede5d5;">
              <div style="font-family:'Playfair Display',Georgia,serif; font-size:0.65rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:#b8860b; margin-bottom:0.5rem;">
                ESV® Bible
              </div>
              <h1 id="passage-title"
                style="font-family:'Playfair Display',Georgia,serif; font-size:2.25rem; font-weight:700; color:#2c1810; margin:0 0 0.25rem;">
                Psalm
              </h1>
              <p id="chapter-label"
                style="font-family:'Playfair Display',Georgia,serif; font-size:1.2rem; color:#8b6353; margin:0; font-style:italic;">
                Chapter 23
              </p>
              <p id="reading-time"
                style="font-family:'EB Garamond',Georgia,serif; font-size:0.8rem; color:#c4873a; margin-top:0.4rem; display:none;">
              </p>
            </header>

            <div id="passage-content" class="prose-scripture">
              <Fragment set:html={psalm23Html} />
            </div>

            <footer style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid #ede5d5; text-align:center;">
              <p style="font-family:'EB Garamond',Georgia,serif; font-size:0.8rem; color:#c4873a; line-height:1.6;">
                Scripture quotations are from the ESV® Bible (The Holy Bible, English Standard Version®),
                copyright © 2001 by Crossway, a publishing ministry of Good News Publishers.
                Used by permission. All rights reserved.
              </p>
            </footer>
          </article>

        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  .prose-scripture {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.2rem;
    line-height: 1.9;
    color: #2a1a10;
  }
  .prose-scripture h2, .prose-scripture h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: #5a311a;
    margin: 1.5rem 0 0.4rem;
    font-style: italic;
  }
  .prose-scripture p { margin-bottom: 0.6em; }
  .prose-scripture :global(.small-caps) { font-variant: small-caps; letter-spacing: 0.04em; }
  .prose-scripture :global(.verse-num), .prose-scripture :global(b.verse-num) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.65em;
    font-weight: 700;
    color: #b8860b;
    vertical-align: super;
    line-height: 0;
    margin-right: 0.2em;
    font-style: normal;
  }
  .prose-scripture :global(.chapter-num) {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.5em;
    font-weight: 700;
    color: #b8860b;
    float: left;
    line-height: 0.8;
    margin-right: 0.08em;
  }
  .prose-scripture :global(.woc) { color: #8b1a1a; }
  .prose-scripture :global(.extra_text), .prose-scripture :global(.audio) { display: none; }
  .prose-scripture :global(.block-indent) { margin-left: 1.5em; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .book-btn:hover { background: #f0d9b0 !important; }
  .book-btn.active { background: #e5c07e !important; font-weight: 600; }
  @media (min-width: 1024px) {
    .lg-show { display: block !important; }
  }
</style>

<script define:vars={{ booksJson: JSON.stringify(booksFlat) }}>
  const books = JSON.parse(booksJson);
  const ESV_TOKEN = 'e2ce4d1b60dc9181904eb7832e3e38c398d7c93c';

  let currentBook = 'psalms';
  let currentChapter = 23;

  function getBook(slug) {
    return books.find(b => b.slug === slug);
  }

  function setHash(book, ch) {
    history.replaceState(null, '', `#${book}/${ch}`);
  }

  function updateNav(bookName, chapter, maxChapters) {
    document.getElementById('passage-title').textContent = bookName;
    document.getElementById('chapter-label').textContent = `Chapter ${chapter}`;
    const sel = document.getElementById('chapter-select');
    sel.innerHTML = Array.from({ length: maxChapters }, (_, i) => {
      const n = i + 1;
      return `<option value="${n}"${n === chapter ? ' selected' : ''}>${n}</option>`;
    }).join('');
    const bookSel = document.getElementById('book-select');
    bookSel.value = currentBook;
    document.querySelectorAll('.book-btn').forEach(btn => {
      const isActive = btn.dataset.book === currentBook;
      btn.classList.toggle('active', isActive);
      if (isActive) btn.scrollIntoView({ block: 'nearest' });
    });
  }

  async function loadChapter(bookSlug, chapter, fromStaticLoad) {
    const book = getBook(bookSlug);
    if (!book) return;
    currentBook = bookSlug;
    currentChapter = chapter;
    setHash(bookSlug, chapter);
    updateNav(book.name, chapter, book.chapters);
    document.getElementById('scroll-area')?.scrollTo(0, 0);

    // Psalm 23 is embedded statically — no fetch needed
    if (bookSlug === 'psalms' && chapter === 23 && fromStaticLoad) {
      showArticle();
      return;
    }

    showLoading();
    try {
      const params = new URLSearchParams({
        q: `${book.name} ${chapter}`,
        'include-headings': 'true',
        'include-footnotes': 'false',
        'include-verse-numbers': 'true',
        'include-short-copyright': 'false',
        'include-passage-horizontal-lines': 'false',
        'include-heading-horizontal-lines': 'false',
      });
      const res = await fetch(`https://api.esv.org/v3/passage/html/?${params}`, {
        headers: { Authorization: `Token ${ESV_TOKEN}` },
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      let html = data.passages?.[0] ?? '';
      if (!html) throw new Error('empty');
      html = html
        .replace(/<small class="audio extra_text">[\s\S]*?<\/small>/g, '')
        .replace(/<div class="footnotes extra_text">[\s\S]*?<\/div>/gs, '')
        .replace(/<p>\(<a href="http:\/\/www\.esv\.org"[^>]*>ESV<\/a>\)<\/p>/g, '');
      document.getElementById('passage-content').innerHTML = html;
      const wordCount = html.replace(/<[^>]+>/g, ' ').trim().split(/\s+/).length;
      const mins = Math.max(1, Math.ceil(wordCount / 200));
      const rt = document.getElementById('reading-time');
      rt.textContent = `~${mins} min read`;
      rt.style.display = '';
      showArticle();
    } catch (e) {
      console.warn('ESV API error:', e.message);
      showError();
    }
  }

  function showLoading() {
    document.getElementById('loading').style.display = '';
    document.getElementById('error-state').style.display = 'none';
    document.getElementById('scripture-article').style.display = 'none';
  }
  function showArticle() {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error-state').style.display = 'none';
    document.getElementById('scripture-article').style.display = '';
  }
  function showError() {
    document.getElementById('loading').style.display = 'none';
    document.getElementById('error-state').style.display = '';
    document.getElementById('scripture-article').style.display = 'none';
  }

  // Event listeners
  document.getElementById('prev-btn').addEventListener('click', () => {
    if (currentChapter > 1) {
      loadChapter(currentBook, currentChapter - 1, false);
    } else {
      const idx = books.findIndex(b => b.slug === currentBook);
      if (idx > 0) {
        const prev = books[idx - 1];
        loadChapter(prev.slug, prev.chapters, false);
      }
    }
  });

  document.getElementById('next-btn').addEventListener('click', () => {
    const book = getBook(currentBook);
    if (currentChapter < book.chapters) {
      loadChapter(currentBook, currentChapter + 1, false);
    } else {
      const idx = books.findIndex(b => b.slug === currentBook);
      if (idx < books.length - 1) {
        loadChapter(books[idx + 1].slug, 1, false);
      }
    }
  });

  document.getElementById('chapter-select').addEventListener('change', e => {
    loadChapter(currentBook, parseInt(e.target.value, 10), false);
  });

  document.getElementById('book-select').addEventListener('change', e => {
    loadChapter(e.target.value, 1, false);
  });

  document.querySelectorAll('.book-btn').forEach(btn => {
    btn.addEventListener('click', () => loadChapter(btn.dataset.book, 1, false));
  });

  document.getElementById('sidebar-toggle').addEventListener('click', () => {
    const sidebar = document.getElementById('bible-sidebar');
    const isVisible = sidebar.style.display !== 'none' && sidebar.style.display !== '';
    sidebar.style.display = isVisible ? 'none' : 'block';
  });

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLSelectElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === 'ArrowLeft') document.getElementById('prev-btn').click();
    if (e.key === 'ArrowRight') document.getElementById('next-btn').click();
  });

  // URL params: /bible/?book=psalms&chapter=23 or hash: #psalms/23
  const urlParams = new URLSearchParams(window.location.search);
  const pBook = urlParams.get('book')?.toLowerCase();
  const pChapter = parseInt(urlParams.get('chapter') || '1', 10);
  const hashParts = window.location.hash.slice(1).split('/');
  const hBook = hashParts[0] || '';
  const hChapter = parseInt(hashParts[1] || '1', 10);

  let initBook = 'psalms', initChapter = 23, isStatic = true;
  if (pBook) {
    const found = books.find(b => b.slug === pBook || b.name.toLowerCase() === pBook);
    if (found) { initBook = found.slug; initChapter = pChapter; isStatic = false; }
  } else if (hBook) {
    const found = books.find(b => b.slug === hBook);
    if (found) { initBook = found.slug; initChapter = hChapter; isStatic = false; }
  }

  loadChapter(initBook, initChapter, isStatic);
</script>
