---
import BaseLayout from '../../layouts/BaseLayout.astro';
import studiesData from '../../data/studies.json';

export function getStaticPaths() {
  return studiesData.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;

const currentIndex = studiesData.findIndex((s) => s.slug === study.slug);
const prevStudy = currentIndex > 0 ? studiesData[currentIndex - 1] : null;
const nextStudy = currentIndex < studiesData.length - 1 ? studiesData[currentIndex + 1] : null;

const relatedStudies = studiesData
  .filter((s) => s.slug !== study.slug && s.theme === study.theme)
  .slice(0, 2);

const continueStudies =
  relatedStudies.length > 0
    ? relatedStudies
    : studiesData.filter((s) => s.slug !== study.slug).slice(0, 2);
---

<BaseLayout
  title={study.title}
  description={study.description}
  path={`/studies/${study.slug}/`}
>

  <!-- STUDY HEADER -->
  <div class="bg-brown-900 border-b border-parchment-800/20">
    <div class="container-upper py-12 md:py-16">

      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-xs font-display tracking-wide">
          <li><a href="/the-upper-room/" class="text-parchment-500 hover:text-parchment-300 transition-colors">Home</a></li>
          <li class="text-parchment-700">/</li>
          <li><a href="/the-upper-room/studies/" class="text-parchment-500 hover:text-parchment-300 transition-colors">Studies</a></li>
          <li class="text-parchment-700">/</li>
          <li class="text-parchment-400 truncate max-w-xs">{study.title}</li>
        </ol>
      </nav>

      <div class="flex items-center gap-4 mb-4">
        <span class="inline-block bg-gold-500/20 border border-gold-500/40 text-gold-400 text-xs font-display font-semibold tracking-widest uppercase px-3 py-1 rounded-sm">
          {study.theme}
        </span>
        <span class="text-parchment-500 text-sm font-serif">{study.date}</span>
      </div>

      <h1 class="font-display text-display-md md:text-display-lg font-bold text-parchment-100 mb-4 leading-tight max-w-3xl">
        {study.title}
      </h1>

      <p class="font-serif text-parchment-300 text-lg leading-relaxed max-w-2xl mb-8">
        {study.description}
      </p>

      <div class="flex flex-wrap gap-2 mb-8">
        {study.passages.map((passage) => (
          <span class="inline-block bg-brown-950/60 border border-parchment-700/30 text-parchment-300 text-xs font-serif px-3 py-1 rounded-sm">
            {passage}
          </span>
        ))}
      </div>

      <div class="border-t border-parchment-800/30 pt-6">
        <p class="text-label text-parchment-600 mb-3">In This Study</p>
        <ol class="flex flex-col gap-1.5 sm:grid sm:grid-cols-2 md:grid-cols-3">
          {study.outline.map((item, i) => (
            <li class="flex items-start gap-2 text-sm text-parchment-400 font-serif">
              <span class="text-gold-500 font-display font-semibold flex-shrink-0 mt-0.5">{i + 1}.</span>
              <span>{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>

  <!-- STUDY BODY -->
  <div class="container-upper py-12 md:py-16" data-pagefind-body>
    <div class="max-w-prose-wide mx-auto">

      {study.sections.map((section, sectionIndex) => (
        <article class="mb-16 md:mb-20" id={`section-${sectionIndex + 1}`}>

          <div class="flex items-start gap-4 mb-7">
            <div class="section-num-badge flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center">
              <span class="font-display font-bold text-sm text-gold-500">{sectionIndex + 1}</span>
            </div>
            <div>
              <p class="text-label text-gold-600 mb-1">Section {sectionIndex + 1} of {study.sections.length}</p>
              <h2 class="font-display text-2xl md:text-3xl font-bold text-brown-900 leading-tight">
                {section.title}
              </h2>
            </div>
          </div>

          <div class="scripture-block mb-8 pl-5 md:pl-6">
            <p class="scripture-ref font-display font-semibold mb-3">
              {section.scriptureRef} &mdash; World English Bible
            </p>
            <p class="font-serif italic text-brown-800 leading-relaxed text-base md:text-lg">
              {section.scriptureText}
            </p>
          </div>

          <div class="flex items-center gap-4 mb-8">
            <div class="flex-1 border-t border-parchment-200"></div>
            <span class="text-gold-500 text-xs">✦</span>
            <div class="flex-1 border-t border-parchment-200"></div>
          </div>

          <div class="font-serif text-brown-800 leading-relaxed text-base md:text-lg space-y-5 mb-10">
            {section.reflection.split('\n\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>

          <div class="prayer-block rounded-sm px-6 md:px-8 py-6">
            <p class="prayer-label font-display font-semibold mb-3">A Prayer</p>
            <p class="font-serif italic text-brown-700 leading-relaxed text-base md:text-lg">
              {section.prayer}
            </p>
          </div>

          {sectionIndex < study.sections.length - 1 && (
            <div class="border-t border-parchment-200 mt-14 opacity-60"></div>
          )}
        </article>
      ))}

      <div class="flex items-center justify-center gap-4 my-10">
        <div class="w-16 border-t border-parchment-300"></div>
        <span class="text-gold-500">✦</span>
        <div class="w-16 border-t border-parchment-300"></div>
      </div>

    </div>
  </div>

  <!-- NAVIGATION -->
  <div class="bg-parchment-100 border-t border-parchment-200">
    <div class="container-upper py-12">

      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        {prevStudy ? (
          <a href={`/the-upper-room/studies/${prevStudy.slug}/`} class="group flex-1 card-parchment hover:bg-parchment-200 transition-all duration-200">
            <p class="text-label text-parchment-500 mb-1">&larr; Previous Study</p>
            <p class="font-display font-semibold text-brown-900 group-hover:text-brown-700 leading-snug">{prevStudy.title}</p>
            <p class="text-xs font-display text-gold-600 mt-1">{prevStudy.theme}</p>
          </a>
        ) : (
          <div class="flex-1" />
        )}
        {nextStudy ? (
          <a href={`/the-upper-room/studies/${nextStudy.slug}/`} class="group flex-1 card-parchment hover:bg-parchment-200 transition-all duration-200 text-right">
            <p class="text-label text-parchment-500 mb-1">Next Study &rarr;</p>
            <p class="font-display font-semibold text-brown-900 group-hover:text-brown-700 leading-snug">{nextStudy.title}</p>
            <p class="text-xs font-display text-gold-600 mt-1">{nextStudy.theme}</p>
          </a>
        ) : (
          <div class="flex-1" />
        )}
      </div>

      {continueStudies.length > 0 && (
        <div>
          <div class="flex items-center gap-4 mb-6">
            <p class="text-label text-brown-800">
              {relatedStudies.length > 0 ? `More on ${study.theme}` : 'Continue Reading'}
            </p>
            <div class="flex-1 border-t border-parchment-200"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {continueStudies.map((related) => (
              <a href={`/the-upper-room/studies/${related.slug}/`} class="group card-parchment hover:bg-parchment-200 transition-all duration-200">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-label text-gold-600">{related.theme}</span>
                  <span class="text-parchment-400 text-xs">·</span>
                  <span class="text-parchment-500 text-xs">{related.date}</span>
                </div>
                <h3 class="font-display font-bold text-brown-900 group-hover:text-brown-700 leading-snug mb-2">{related.title}</h3>
                <p class="text-brown-600 text-sm leading-relaxed line-clamp-2">{related.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-10 pt-8 border-t border-parchment-200 flex items-center justify-between flex-wrap gap-4">
        <a href="/the-upper-room/studies/" class="btn-outline text-sm">&larr; All Studies</a>
        <a href="/the-upper-room/bible/" class="font-display text-sm text-brown-600 hover:text-brown-900 transition-colors">
          Open Bible Reader &rarr;
        </a>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  .section-num-badge {
    background: rgba(184, 134, 11, 0.12);
    border: 1px solid rgba(184, 134, 11, 0.3);
  }
  .scripture-block {
    border-left: 4px solid #b8860b;
  }
  .scripture-ref {
    font-size: 0.68rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #b8860b;
  }
  .prayer-block {
    background: #f8eddb;
    border: 1px solid #f0d9b0;
  }
  .prayer-label {
    font-size: 0.68rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #b8860b;
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
